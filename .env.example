NEXT_PUBLIC_APP_TIMEZONE=Europe/Istanbul

# Browser tarafında yalnızca anon/public key kullanılır.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Netlify Functions tarafında kullanılır. Tarayıcıya koymayın.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SOCIALFLOW_ORGANIZATION_ID=
SOCIALFLOW_SOCIAL_ACCOUNT_ID=
SOCIALFLOW_DEFAULT_PROFILE_ID=

# Meta / Instagram Graph API. Tarayıcıya koymayın.
META_GRAPH_API_VERSION=v24.0
META_INSTAGRAM_BUSINESS_ACCOUNT_ID=
META_ACCESS_TOKEN=
